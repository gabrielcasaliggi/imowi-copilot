# LLM — desarrollo local (Ollama)
AI_BASE_URL=http://localhost:11434/v1
AI_API_KEY=ollama
AI_MODEL=llama3.2

# LLM — producción (Groq u otro compatible OpenAI)
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_API_KEY=
# AI_MODEL=llama-3.3-70b-versatile

# Entorno: development | production
APP_ENV=development

# Auth JWT (obligatorio en producción — generá uno: openssl rand -hex 32)
# AUTH_SECRET=
AUTH_TOKEN_HOURS=72

# Usuarios demo (opcional — por defecto admin/admin y coop_prueba/prueba)
# ADMIN_USER=admin
# ADMIN_PASSWORD=cambiar-en-produccion
# COOP_USER=coop_prueba
# COOP_PASSWORD=cambiar-en-produccion
# COOP_NOMBRE=Operador Prueba
# COOP_COOPERATIVA=Cooperativa Prueba
# MOCK_USERS_JSON={"mi_coop":{"password":"xxx","rol":"cooperativa","cooperativa":"Coop X","nombre":"Operador"}}

# Supabase — tickets (recomendado en producción)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_KEY=eyJ...   # service_role — SOLO backend, nunca Netlify

# CORS — en prod: dominio Netlify (sin barra final)
# CORS_ORIGINS=https://tu-app.netlify.app

# RAG
# KNOWLEDGE_MIN_SCORE=0.15
# KNOWLEDGE_TOP_K=1

# Persistencia JSON local (solo dev sin Supabase)
# DATA_DIR=./data

# Frontend Netlify (build) — URL pública de la API en Render
# IMOWI_API_URL=https://imowi-copilot-api.onrender.com

# Servidor local
# HOST=0.0.0.0
# PORT=8000

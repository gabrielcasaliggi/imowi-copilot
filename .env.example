# LLM — desarrollo local (Ollama)
AI_BASE_URL=http://localhost:11434/v1
AI_API_KEY=ollama
AI_MODEL=llama3.2

# LLM — producción (Groq u otro compatible OpenAI)
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_API_KEY=
# AI_MODEL=llama-3.3-70b-versatile

# Entorno: development | production
APP_ENV=development

# Auth JWT (obligatorio en producción — generá uno: openssl rand -hex 32)
# AUTH_SECRET=
AUTH_TOKEN_HOURS=72

# Usuarios demo (opcional — por defecto admin/admin y coop_prueba/prueba)
# ADMIN_USER=admin
# ADMIN_PASSWORD=cambiar-en-produccion
# COOP_USER=coop_prueba
# COOP_PASSWORD=cambiar-en-produccion
# COOP_NOMBRE=Operador Prueba
# COOP_COOPERATIVA=Cooperativa Prueba
# MOCK_USERS_JSON={"mi_coop":{"password":"xxx","rol":"cooperativa","cooperativa":"Coop X","nombre":"Operador"}}

# Data Estate — SQLite local (dev) o PostgreSQL Supabase (producción)
# DATABASE_URL=sqlite:///./data/estate.db
# Producción (Supabase → Settings → Database → Connection string → URI, modo Transaction pooler):
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-xx.pooler.supabase.com:6543/postgres
# DATABASE_SSLMODE=require

# Supabase REST — espejo legacy de tickets (opcional si DATABASE_URL ya es el mismo Postgres)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_KEY=eyJ...   # service_role — SOLO backend

# CORS — orígenes del frontend (sin barra final, separados por coma)
# Dev Next.js: http://localhost:3000
# CORS_ORIGINS=http://localhost:3000,https://tu-app.vercel.app

# Frontend Next.js (separado del backend)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# RAG — búsqueda por keywords (no inyectar KB completa; evita 413 en Groq)
# KNOWLEDGE_MIN_SCORE=0.15
# KNOWLEDGE_TOP_K=1
# KNOWLEDGE_MAX_FRAGMENT_CHARS=1800
# KNOWLEDGE_MAX_SYSTEM_TOKENS=4500

# Persistencia JSON local (solo dev sin Supabase)
# DATA_DIR=./data

# Frontend Netlify (build) — URL pública de la API en Render
# IMOWI_API_URL=https://imowi-copilot-api.onrender.com

# Servidor local
# HOST=0.0.0.0
# PORT=8000
